# Phase 3 runtime contract
# Railway + Vercel deploy target.
# See DEPLOY_VERCEL_RAILWAY.md for the exact publication checklist.

# Shared app settings
NODE_ENV=production
APP_RUNTIME=api
PORT=3001
BACKEND_PORT=3001
BACKEND_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://*.vercel.app
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# Database
# Prefer DATABASE_URL on Railway. The split variables below remain supported.
DATABASE_URL=
DATABASE_SSL=false
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=omnichannel
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres

# Redis
# Prefer REDIS_URL on Railway. The split variables below remain supported.
REDIS_URL=
REDIS_TLS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379

# Auth
JWT_SECRET=your-jwt-secret-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# AI / embeddings
OPENAI_API_KEY=your-openai-api-key

# Stripe billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PROFESSIONAL=
STRIPE_PRICE_ENTERPRISE=

# WhatsApp Cloud API
WHATSAPP_API_VERSION=v21.0
WHATSAPP_APP_SECRET=
WHATSAPP_VERIFY_TOKEN=

# S3 / MinIO
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=
S3_REGION=us-east-1

# Tracing / OTLP
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=whatsapp-post-tool-backend
