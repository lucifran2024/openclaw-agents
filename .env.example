# Phase 3 runtime contract
# Core backend runtime below is validated at Nest bootstrap time.
# See PHASE_3_CLOSURE.md for what is already validated and what still depends on a real environment.

# App
NODE_ENV=development
BACKEND_PORT=3001
BACKEND_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# Core runtime: database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=omnichannel
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres

# Core runtime: Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Core runtime: auth
JWT_SECRET=your-jwt-secret-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Core runtime: AI / embeddings
OPENAI_API_KEY=your-openai-api-key

# Feature-conditional: Stripe checkout, portal, invoices and webhook
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret
STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key
STRIPE_PRICE_STARTER=price_starter
STRIPE_PRICE_PROFESSIONAL=price_professional
STRIPE_PRICE_ENTERPRISE=price_enterprise

# Feature-conditional: WhatsApp Cloud API and webhook verification
WHATSAPP_API_VERSION=v21.0
WHATSAPP_APP_SECRET=your-app-secret
WHATSAPP_VERIFY_TOKEN=your-verify-token

# Feature-conditional: S3 / MinIO
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=omnichannel
S3_REGION=us-east-1

# Feature-conditional: tracing / OTLP
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=whatsapp-post-tool-backend
