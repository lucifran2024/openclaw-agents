FROM node:20-alpine AS builder
WORKDIR /app

COPY pnpm-lock.yaml pnpm-workspace.yaml package.json ./
COPY packages/ packages/
COPY apps/backend/ apps/backend/

RUN corepack enable
RUN pnpm install --frozen-lockfile
RUN pnpm --filter @repo/backend build

FROM node:20-alpine
WORKDIR /app

ENV NODE_ENV=production

COPY --from=builder /app/package.json ./package.json
COPY --from=builder /app/pnpm-lock.yaml ./pnpm-lock.yaml
COPY --from=builder /app/pnpm-workspace.yaml ./pnpm-workspace.yaml
COPY --from=builder /app/node_modules ./node_modules
COPY --from=builder /app/packages ./packages
COPY --from=builder /app/apps/backend/package.json ./apps/backend/package.json
COPY --from=builder /app/apps/backend/mikro-orm.config.ts ./apps/backend/mikro-orm.config.ts
COPY --from=builder /app/apps/backend/src/common/database ./apps/backend/src/common/database
COPY --from=builder /app/apps/backend/dist ./apps/backend/dist

WORKDIR /app/apps/backend

EXPOSE 3001

CMD ["node", "dist/main.js"]
